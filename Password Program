#include <iostream>
#include <string>
#include <cstring>
#include <cctype>
#include <clocale>

using namespace std;

void introInstruc();
string input1(); 
void validation(const string& password);

int main() {
    setlocale(LC_ALL, "");
    introInstruc();
    string pwd = input1(); 
    validation(pwd);       
    
    return 0;
}

void introInstruc() {
    cout << "Please enter a password that must contain:\n" 
         << "- At least eight (8) characters and no more than twenty (20)\n"
         << "- At least one Uppercase letter\n" 
         << "- At least one Lowercase letter\n" 
         << "- At least one number\n\n";
}

string input1() {
    string password;
    cout << "Enter password: ";
    getline(cin, password);
    return password;
}

void validation(const string& password) {
    int len = password.length();
    bool isValid = true; // Tracks if the password passes overall

    cout << "\n--- Validation Results ---\n";

    // 1. Length check
    if (len < 8 || len > 20) {
        cout << "[X] Error: Password must be between 8 and 20 characters long (Current length: " << len << ").\n";
        isValid = false;
    } else {
        cout << "[\u2713] Length requirement met.\n";
    }

    // 2. Rules flags
    bool hasUpper = false;
    bool hasLower = false;
    bool hasNum = false;

    // 3. Loop through each character to check conditions
    for (int i = 0; i < len; i++) {
        if (isupper(password[i])) {
            hasUpper = true;
        } else if (islower(password[i])) {
            hasLower = true;
        } else if (isdigit(password[i])) {
            hasNum = true;
        }
    }

    // 4. Check each flag independently
    if (!hasUpper) {
        cout << "[X] Error: Missing at least one uppercase letter.\n";
        isValid = false;
    } else {
        cout << "[\u2713] Uppercase requirement met.\n";
    }

    if (!hasLower) {
        cout << "[X] Error: Missing at least one lowercase letter.\n";
        isValid = false;
    } else {
        cout << "[\u2713] Lowercase requirement met.\n";
    }

    if (!hasNum) {
        cout << "[X] Error: Missing at least one number.\n";
        isValid = false;
    } else {
        cout << "[\u2713] Number requirement met.\n";
    }

    // 5. Final verdict
    cout << "--------------------------\n";
    if (isValid) {
        cout << "Success! Password meets all requirements.\n";
    } else {
        cout << "Password rejected. Please fix the errors listed above.\n";
    }
}
