#include <iostream>
#include <climits> // For INT_MAX
using namespace std;

// Array definition
int* Array(int numbers) {
    int* arrayPtr = new int[numbers];
    return arrayPtr;
}

double averageWithoutLowest(int a[], int n) {
    if (n <= 1) return 0; // Prevent division by zero

    int minVal = INT_MAX;
    int minIndex = -1;
    int sum = 0;

    for (int i = 0; i < n; i++) {
        sum += a[i]; // Accumulate sum
        if (a[i] < minVal) {
            minVal = a[i]; // Find the lowest value
            minIndex = i;  // Remember its position
        }
    }

    // Subtract ONLY the first occurrence of the lowest value
    sum -= a[minIndex];

    // Calculate average using the remaining (n - 1) elements
    return (double)sum / (n - 1);
}

int main() {
    int size;
    cout << "Enter how many scores there are (at least 2): ";
    cin >> size;

    if (size < 2) {
        cout << "Array must contain at least 2 scores to drop the lowest." << endl;
        return 1;
    }

    int* DynamicArray = Array(size);

    // User inputs the values
    cout << "Enter " << size << " numbers: ";
    for (int i = 0; i < size; i++) {
        cin >> DynamicArray[i];
    }

    // Calculate and display the average
    double avg = averageWithoutLowest(DynamicArray, size);
    cout << "The average score (dropping the lowest score) is: " << avg << endl;

    // Free the dynamically allocated memory
    delete[] DynamicArray;
    return 0;
}
