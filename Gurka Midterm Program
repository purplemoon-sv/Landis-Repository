// Populates the deck array with 52 unique cards (4 suits, 13 ranks each)
void makeDeck() {
	// Arrays containing the human-readable names of card ranks and the Unicode symbols for suits
	string face[] = {"Ace", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine", "Ten", "Jack", "Queen", "King"};
	string symbol[] = {"\u2663", "\u2665", "\u2666", "\u2660"}; // Club, Heart, Diamond, Spade

	int l = 0; // Index pointer for the master deck array

	// Outer loop iterates through each of the 4 suits
	for (int i = 0; i < 4; i++) {
		// Inner loop iterates through each of the 13 ranks
		for (int j = 0; j < 13; j++) {
			// Assign the face string and suit symbol to the current card object
			deck[l].face = face[j];
			deck[l].symbol = symbol[i];
			l++; // Move to the next card slot in the deck
		}
	}
}


// Shuffles the deck using random indices to ensure a unique card order for each round
void shuffle() {
	// Iterate through every card in the standard 52-card deck
	for (int n = 0; n < 52; n++) {
		// Pick a random index between 0 and 51
		int m = rand() % 52;

		// Swap the card at the current position (n) with the card at the random position (m)
		card temp = deck[n];
		deck[n] = deck[m];
		deck[m] = temp;
	}
}

void makeHands() {
