// Validates that the user input is a clean integer with no trailing characters or letters
bool isValidNumeric(int& value) {
	string line;
	// Read the entire line of input to prevent leftover characters in the buffer
	getline(cin, line);

	stringstream ss(line);
	char extra;

	// Check if the input is successfully converted to an integer
	// AND ensure there is no "extra" content (like "12abc") following the number
	if (ss >> value && !(ss >> extra)) {
		return true; // Input is a perfectly valid integer
	}

	return false; // Input was either non-numeric or contained invalid trailing characters
}

