	gameMenu();

	bool gameOver = false;
	while (!gameOver) {
		currentCard = 0;
		for (int i = 0; i < 52; i++) deck[i].isPlayed = false;

		makeDeck();
		shuffle();
		makeHands();

		playGame();

		int activePlayers = 0;
		int lastPlayerStanding = -1;

		cout << "\n----------- STANDINGS -----------\n";
		for (int i = 0; i < numPlayers; i++) {
			if (scores[i] > 0) {
				cout << names[i] << ": " << scores[i] << " points\n";
				activePlayers++;
				lastPlayerStanding = i;
			} else {
				cout << names[i] << ": ELIMINATED\n";
			}
		}
		cout << "---------------------------------\n";

		if (activePlayers <= 1) {
			cout << "\n*** GAME OVER ***\n";
			if (lastPlayerStanding != -1) cout << names[lastPlayerStanding] << " IS THE WINNER!\n";
			else cout << "Everyone was eliminated! It's a draw.\n";
			gameOver = true;
		} else {
			cout << "\nPress Enter for next round...";
			string dummy;
			getline(cin, dummy);
		}
	}
	return 0;
}

