// Class to represent a single playing card in the deck
class card {
public:
	string face;
	string symbol;
	bool isPlayed = false;

	void printCard() {
		cout << face << " of " << symbol;
	}

	int getValue() {
		if (face == "Ace") return 14;
		if (face == "King") return 13;
		if (face == "Queen") return 12;
		if (face == "Jack") return 11;
		if (face == "Ten") return 10;
		if (face == "Nine") return 9;
		if (face == "Eight") return 8;
		if (face == "Seven") return 7;
		if (face == "Six") return 6;
		if (face == "Five") return 5;
		if (face == "Four") return 4;
		if (face == "Three") return 3;
		if (face == "Two") return 2;
		return 0;
	}

	void printCardArt() {
		string rank;
		if (face == "Ace") rank = "A";
		else if (face == "Ten") rank = "10";
		else if (face == "Jack") rank = "J";
		else if (face == "Queen") rank = "Q";
		else if (face == "King") rank = "K";
		else rank = (face == "Two" ? "2" : face == "Three" ? "3" : face == "Four" ? "4" : face == "Five" ? "5" : face == "Six" ? "6" : face == "Seven" ? "7" : face == "Eight" ? "8" : "9");

		string pad = (rank == "10") ? "" : " ";
		cout << ".-----------.\n";
		cout << "| " << rank << pad << "        |\n";
		cout << "|           |\n";
		cout << "|           |\n";
		cout << "|     " << symbol << "     |\n";
		cout << "|           |\n";
		cout << "|           |\n";
		cout << "|        " << pad << rank << " |\n";
		cout << "'-----------'\n";
	}
};

