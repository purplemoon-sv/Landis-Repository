                deck[p * cardsPerHand + c].printCard();
                cout << "\n";
            }
            cout << "\nPress Enter to hide hand for next player...";
            getline(cin, dummy);
            for(int i = 0; i < 50; i++) cout << "\n";
        }
    }
}

// Core gameplay loop for the round
void playGame() {
    // Find the first active player to start
    while (scores[currentStarter] <= 0) {
        currentStarter = (currentStarter + 1) % numPlayers;
    }

    for (int stack = 1; stack <= cardsPerHand; stack++) {
        bool isLastStack = (stack == cardsPerHand);

        cout << "\n==========================================";
        if (isLastStack) cout << "\n*** FINAL STACK (Lowest Wins!) ***";
        else cout << "\nSTACK " << stack;
        cout << "\n==========================================\n";

        int highestValueInStack = 0;
        int targetValue = isLastStack ? 99 : -1;
        int stackWinner = currentStarter;
        int playedValues[5] = {0};
        bool firstActiveInStack = true;

        for (int i = 0; i < numPlayers; i++) {
            int p = (currentStarter + i) % numPlayers;
            if (scores[p] <= 0) continue;

            int currentPlayedValue = 0;
            int startIdx = p * cardsPerHand;

            if (p < numHumans) {
                // --- HUMAN PLAYER TURN ---
                cout << "\n--- " << names[p] << "'s Turn ---"; // UPDATED: Uses custom name
                if (!firstActiveInStack) cout << "\nTo beat: " << highestValueInStack;

                int lowestInHandIdx = -1;
                bool canBeat = false;

                // Determine playable cards based on rules
                for (int j = 0; j < cardsPerHand; j++) {
                    int cardIdx = startIdx + j;
                    if (deck[cardIdx].isPlayed) continue;
                    if (lowestInHandIdx == -1 || deck[cardIdx].getValue() < deck[lowestInHandIdx].getValue()) lowestInHandIdx = cardIdx;
                    if (firstActiveInStack || deck[cardIdx].getValue() >= highestValueInStack) canBeat = true;
                }

                for (int j = 0; j < cardsPerHand; j++) {
                    int cardIdx = startIdx + j;
                    if (!deck[cardIdx].isPlayed) {
                        bool isPlayable = firstActiveInStack || (canBeat && deck[cardIdx].getValue() >= highestValueInStack) || (!canBeat && cardIdx == lowestInHandIdx);
                        cout << "\n" << j + 1 << ": " << deck[cardIdx].face << " of " << deck[cardIdx].symbol;
                        if (isPlayable) cout << " **[PLAYABLE]**";
                    }
                }

                int choice;
                bool valid = false;
                while (!valid) {
                    cout << "\nPick card index: ";
                    if (isValidNumeric(choice) && choice >= 1 && choice <= cardsPerHand && !deck[startIdx + choice - 1].isPlayed) {
                        int chosenIdx = startIdx + choice - 1;
                        int chosenVal = deck[chosenIdx].getValue();
                        bool isPlayable = firstActiveInStack || (canBeat && chosenVal >= highestValueInStack) || (!canBeat && chosenIdx == lowestInHandIdx);

                        if (isPlayable) {
                            deck[chosenIdx].isPlayed = true;
                            currentPlayedValue = chosenVal;
                            deck[chosenIdx].printCardArt();
                            valid = true;
                        } else cout << "Rule violation! You must beat the high card or play your lowest.";
                    } else cout << "Invalid input.";
                }
            } else {
                // --- BOT TURN ---
                int bestWinningIdx = -1, highestInHandIdx = -1, lowestIdx = -1;
                for (int j = 0; j < cardsPerHand; j++) {
                    int cardIdx = startIdx + j;
                    if (deck[cardIdx].isPlayed) continue;
                    if (lowestIdx == -1 || deck[cardIdx].getValue() < deck[lowestIdx].getValue()) lowestIdx = cardIdx;
                    if (highestInHandIdx == -1 || deck[cardIdx].getValue() > deck[highestInHandIdx].getValue()) highestInHandIdx = cardIdx;
                    if (firstActiveInStack || deck[cardIdx].getValue() >= highestValueInStack) {
                        if (bestWinningIdx == -1 || deck[cardIdx].getValue() < deck[bestWinningIdx].getValue()) bestWinningIdx = cardIdx;
                    }
                }
                int playIdx = firstActiveInStack ? highestInHandIdx : (bestWinningIdx != -1 ? bestWinningIdx : lowestIdx);
                if (isLastStack) playIdx = lowestIdx;

                deck[playIdx].isPlayed = true;
                currentPlayedValue = deck[playIdx].getValue();
                cout << "\n" << names[p] << " plays:\n"; // UPDATED: Uses custom name
                deck[playIdx].printCardArt();
            }

            playedValues[p] = currentPlayedValue;
            
            // Stack winner determination
            if (isLastStack) {
                if (currentPlayedValue <= targetValue) {
                    targetValue = currentPlayedValue;
                    stackWinner = p;
                }
            } else {
                if (currentPlayedValue >= targetValue) {
                    targetValue = currentPlayedValue;
                    stackWinner = p;
                }
            }
            if (currentPlayedValue > highestValueInStack) highestValueInStack = currentPlayedValue;
            firstActiveInStack = false;
        }

        currentStarter = stackWinner;

        if (isLastStack) {
            cout << "\n==========================================";
            cout << "\nROUND OVER - FINAL SCORING";
            cout << "\n==========================================\n";
            cout << names[stackWinner] << " won the final stack and loses 0 points!\n\n"; // UPDATED

            for (int p = 0; p < numPlayers; p++) {
                if (scores[p] <= 0) continue;
                if (p != stackWinner) {
                    scores[p] -= playedValues[p];
                    if (scores[p] < 0) scores[p] = 0;
                    cout << names[p] << " lost " << playedValues[p] << " points. New Total: " << scores[p] << "\n"; // UPDATED
                } else {
                    cout << names[p] << " (Winner) maintains: " << scores[p] << "\n"; // UPDATED
                }
            }
        } else {
            cout << "\n>>> " << names[stackWinner] << " wins this stack! <<<\n"; // UPDATED
        }
    }
}
