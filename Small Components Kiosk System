// Handles category selection for inventory transactions
void kioskSystem(const vector<string>& rLabels, vector<int>& rStock,
                 const vector<string>& cLabels, vector<int>& cStock,
                 const vector<string>& lLabels, vector<int>& lStock,
                 const vector<string>& icLabels, vector<int>& icStock,
                 const vector<string>& pLabels, vector<int>& pStock,
                 const vector<string>& iLabels, vector<int>& iStock,
                 const vector<string>& bsLabels, vector<int>& bsStock,
                 const vector<string>& bLabels, vector<int>& bStock,
                 const vector<string>& brLabels, vector<int>& brStock) {
	int category;
	cout << "\nTransaction - Select Category:" << endl;
	cout << "1. Resistors\n2. Capacitors\n3. LEDs\n4. IC Chips\n5. Potentiometers\n6. Inductors\n7. Buttons/Switches\n8. Batteries\n9. Breadboards" << endl;
	cout << "Selection: ";
	cin >> category;

	// Direct user to the selected inventory category
	if (category == 1) processTransaction(rLabels, rStock, "Resistor");
	else if (category == 2) processTransaction(cLabels, cStock, "Capacitor");
	else if (category == 3) processTransaction(lLabels, lStock, "LED");
	else if (category == 4) processTransaction(icLabels, icStock, "IC Chip");
	else if (category == 5) processTransaction(pLabels, pStock, "Potentiometer");
	else if (category == 6) processTransaction(iLabels, iStock, "Inductor");
	else if (category == 7) processTransaction(bsLabels, bsStock, "Button/Switch");
	else if (category == 8) processTransaction(bLabels, bStock, "Battery");
	else if (category == 9) processTransaction(brLabels, brStock, "Breadboard");
	else cout << "Invalid category selection." << endl;  // Prevent invalid category selection
}

// Process and edits inventory
void processTransaction(const vector<string>& labels, vector<int>& stock, string typeName) {
	int partChoice;
	int action, quantity;

	// Display numbered inventory list
	cout << "\n--- " << typeName << " LIST ---" << endl;

	for (size_t i = 0; i < labels.size(); ++i) {
		cout << setw(3) << i + 1 << ". "
		     << left << setw(25) << labels[i]
		     << "Stock: " << stock[i] << endl;
	}

	// Ask user to select part number
	cout << "\nEnter part number: ";
	cin >> partChoice;

	// Validate selection
	if (partChoice < 1 || partChoice > labels.size()) {
		cout << "Invalid part selection." << endl;
		return;
	}

	// Convert user selection to vector index
	int index = partChoice - 1;

	cout << "\nSelected Part: " << labels[index]
	     << "\nCurrent Stock: " << stock[index] << endl;

	// Ask transaction type
	cout << "\n1. Check-out (Remove)"
	     << "\n2. Check-in (Add)"
	     << "\nSelection: ";
	cin >> action;

	// Ask quantity
	cout << "Enter quantity: ";
	cin >> quantity;

	// Validate quantity
	if (quantity <= 0) {
		cout << "Invalid quantity." << endl;
		return;
	}

	// Check-out
	if (action == 1) {

		if (stock[index] >= quantity) {
			stock[index] -= quantity;

			cout << "Success! New stock: "
			     << stock[index] << endl;
		}
		else {
			cout << "Error: Insufficient stock available." << endl;
		}

	}

	// Check-in
	else if (action == 2) {

		stock[index] += quantity;

		cout << "Success! New stock: "
		     << stock[index] << endl;
	}

	// Invalid action
	else {
		cout << "Invalid action." << endl;
	}
}
