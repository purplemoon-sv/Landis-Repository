// Validated integer input
bool getValidatedInt(int& value) {

	if (!(cin >> value)) {

		cin.clear();

		cin.ignore(numeric_limits<streamsize>::max(), '\n');

		return false;
	}

	return true;
}

// Verify labels and stock sizes match
bool validateCategoryData(const vector<Category>& categories) {

	for (const auto& category : categories) {

		if (category.labels.size() != category.stock.size()) {

			cout << "Mismatch detected in category: "
			     << category.name << endl;

			return false;
		}
	}

	return true;
}

// Main menu
void intro(int& menuInput) {

	cout << "\n===============================" << endl;
	cout << "      COMPONENT KIOSK" << endl;
	cout << "===============================" << endl;
	cout << "1. See full inventory" << endl;
	cout << "2. Check-out/Check-in parts" << endl;
	cout << "0. Exit" << endl;
	cout << "Selection: ";

	if (!getValidatedInt(menuInput)) {

		cout << "Invalid input." << endl;

		menuInput = -1;
	}
}

// Display inventory
void inventoryFull(const vector<Category>& categories) {

	int choice;

	cout << "\nChoose category to view:" << endl;

	for (size_t i = 0; i < categories.size(); ++i) {

		cout << i + 1 << ". "
		     << categories[i].name << endl;
	}

	cout << "Selection: ";

	if (!getValidatedInt(choice)) {

		cout << "Invalid input." << endl;
		return;
	}

	if (choice < 1 || choice > static_cast<int>(categories.size())) {

		cout << "Invalid category selection." << endl;
		return;
	}

	const Category& selected = categories[choice - 1];

	cout << "\n--- "
	     << selected.name
	     << " INVENTORY ---" << endl;

	cout << left
	     << setw(5) << "#"
	     << setw(25) << "PART NAME"
	     << "STOCK LEVEL" << endl;

	cout << "------------------------------------------" << endl;

	for (size_t i = 0; i < selected.labels.size(); ++i) {

		cout << left
		     << setw(5) << i + 1
		     << setw(25) << selected.labels[i]
		     << selected.stock[i] << endl;
	}
}

// Handles transactions
void kioskSystem(vector<Category>& categories) {

	int category;

	cout << "\nTransaction - Select Category:" << endl;

	for (size_t i = 0; i < categories.size(); ++i) {

		cout << i + 1 << ". "
		     << categories[i].name << endl;
	}

	cout << "Selection: ";

	if (!getValidatedInt(category)) {

		cout << "Invalid input." << endl;
		return;
	}

	if (category < 1 || category > static_cast<int>(categories.size())) {

		cout << "Invalid category selection." << endl;
		return;
	}

	processTransaction(categories[category - 1]);
}

// Process inventory transactions
void processTransaction(Category& category) {

	int partChoice;
	int action;
	int quantity;

	cout << "\n--- "
	     << category.name
	     << " LIST ---" << endl;

	for (size_t i = 0; i < category.labels.size(); ++i) {

		cout << setw(3) << i + 1 << ". "
		     << left << setw(25)
		     << category.labels[i]
		     << "Stock: "
		     << category.stock[i]
		     << endl;
	}

	cout << "\nEnter part number: ";

	if (!getValidatedInt(partChoice)) {

		cout << "Invalid input." << endl;
		return;
	}

	if (partChoice < 1 ||
	    partChoice > static_cast<int>(category.labels.size())) {

		cout << "Invalid part selection." << endl;
		return;
	}

	int index = partChoice - 1;

	cout << "\nSelected Part: "
	     << category.labels[index]
	     << "\nCurrent Stock: "
	     << category.stock[index]
	     << endl;

	cout << "\n1. Check-out (Remove)"
	     << "\n2. Check-in (Add)"
	     << "\nSelection: ";

	if (!getValidatedInt(action)) {

		cout << "Invalid input." << endl;
		return;
	}

	cout << "Enter quantity: ";

	if (!getValidatedInt(quantity)) {

		cout << "Invalid input." << endl;
		return;
	}

	if (quantity <= 0) {

		cout << "Invalid quantity." << endl;
		return;
	}

	// Check-out
	if (action == 1) {

		if (category.stock[index] >= quantity) {

			category.stock[index] -= quantity;

			cout << "Success! New stock: "
			     << category.stock[index]
			     << endl;
		}

		else {

			cout << "Error: Insufficient stock available."
			     << endl;
		}
	}

	// Check-in
	else if (action == 2) {

		category.stock[index] += quantity;

		cout << "Success! New stock: "
		     << category.stock[index]
		     << endl;
	}

	// Invalid action
	else {

		cout << "Invalid action." << endl;
	}
}
